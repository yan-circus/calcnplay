; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

[application]

config/name="calc&play"
config/description="This is a calculation game."
run/main_scene="res://ui/pages/main.tscn"
config/icon="res://icon.png"

[autoload]

GlobalVariables="*res://globals/global_variables.gd"
QuestionsManager="*res://ui/add_scripts/questions_manager.gd"
UsersManager="*res://ui/add_scripts/users_manager.gd"

[display]

window/size/width=1366
window/size/height=768
window/stretch/mode="2d"
window/stretch/aspect="keep"

[editor_plugins]

enabled=PoolStringArray(  )

[gdnative]

singletons=[  ]

[global]

viewpo=false
resol=false
displ=false

